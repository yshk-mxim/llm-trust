# release/ is a SELF-CONTAINED artifact. The monorepo root .gitignore globally ignores runs/, *.jsonl, and
# *.log (tuned for ML-training junk at the root); re-include them here so the artifact's data inputs and run
# outputs ARE tracked (nothing lost). Caches + editor junk stay ignored. Re-add a line to stop tracking it.
!runs/
!**/*.jsonl
!**/*.log
__pycache__/
*.pyc
.DS_Store
*.bak
.mypy_cache/
.pytest_cache/
.ruff_cache/

# hypothesis example database (property tests) -- local cache, not tracked
.hypothesis/

# transient per-cascade final_eval resume logs: fingerprint-named, regenerated by every eval run
# (and by the cache unit test). The canonical outputs are final_eval.jsonl/_summary.json/_tagged.jsonl.
runs/final_eval_[0-9a-f]*.jsonl

# the publishable export produced by `make dist` (a git archive of tracked files) is itself never tracked
dist/
